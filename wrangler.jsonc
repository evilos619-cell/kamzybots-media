{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kamzybotsmedia",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "observability": {
    "logs": {
      "enabled": false,
      "invocation_logs": true
  "routes": [
    {
      "pattern": "kamzybotsmedia.store/*",
      "zone_name": "kamzybotsmedia.store"
    }
  ]
}
